const prisma = require("../prisma");
const slugify = require("slugify");

/* -------------------------- helpers pequeños -------------------------- */
const isFilled = (v) =>
  typeof v === "string" ? v.trim().length > 0 : v != null;

const toStr = (v) =>
  typeof v === "string" ? v.trim() : v == null ? "" : String(v).trim();

const parseBool = (v) => {
  if (v === true) return true;
  if (v === false) return false;
  if (typeof v === "string") {
    const s = v.trim().toLowerCase();
    return s === "true" || s === "1" || s === "on" || s === "yes";
  }
  return Boolean(v);
};

const clampInt = (n, min, max, fallback) => {
  const x = Number(n);
  if (!Number.isFinite(x)) return fallback;
  return Math.max(min, Math.min(max, Math.trunc(x)));
};

/* ------------------------------ crear --------------------------------- */
/** Crear (si lo llamas desde otra capa) */
exports.crear = async (data) => {
  const slug = slugify(data.nombre, { lower: true, strict: true });
  return prisma.restaurante.create({
    data: {
      ...data,
      slug,
      imagenes: Array.isArray(data.imagenes) ? data.imagenes : [],
    },
  });
};

/* --------------------- listado con filtros + paginación ----------------
 * opts:
 *  - q: string (búsqueda libre en varios campos)
 *  - ciudad, localidad: string (si llega cualquiera, se usa OR)
 *  - onlyWithCoords: boolean ("true"/"1"/true)
 *  - flags: objeto con booleanos (zonaAmplia, parqueCercano, etc.)
 *  - matchMode: "all" | "any"  (cómo combinar flags)
 *  - sortBy: "nombre_asc" | "nombre_desc" | "ciudad_asc" | "ciudad_desc"
 *  - page: number  (>=1)
 *  - pageSize: number (1..100)
 */
exports.obtenerFiltrados = async (opts = {}) => {
  // Normalizamos inputs
  const q = toStr(opts.q);
  const ciudad = toStr(opts.ciudad);
  const localidad = toStr(opts.localidad);
  const onlyWithCoords = parseBool(opts.onlyWithCoords);
  const matchMode = opts.matchMode === "any" ? "any" : "all";
  const sortBy = toStr(opts.sortBy) || "nombre_asc";

  // Paginación segura
  const page = clampInt(opts.page, 1, 1_000_000, 1);
  const pageSize = clampInt(opts.pageSize, 1, 100, 10);
  const skip = (page - 1) * pageSize;
  const take = pageSize;

  // where dinámico
  const AND = [];

  if (isFilled(q)) {
    AND.push({
      OR: [
        { nombre: { contains: q, mode: "insensitive" } },
        { direccion: { contains: q, mode: "insensitive" } },
        { ciudad: { contains: q, mode: "insensitive" } },
        { localidad: { contains: q, mode: "insensitive" } },
        { descripcion: { contains: q, mode: "insensitive" } },
      ],
    });
  }

  if (isFilled(ciudad) || isFilled(localidad)) {
    const c = isFilled(ciudad) ? ciudad : localidad;
    AND.push({
      OR: [
        { ciudad: { contains: c, mode: "insensitive" } },
        { localidad: { contains: c, mode: "insensitive" } },
      ],
    });
  }

  if (onlyWithCoords) {
    AND.push({ latitud: { not: null } }, { longitud: { not: null } });
  }

  // Flags
  const rawFlags =
    opts.flags && typeof opts.flags === "object" ? opts.flags : {};
  const selectedFlags = Object.entries(rawFlags)
    .filter(([, v]) => parseBool(v))
    .map(([k]) => k);

  if (selectedFlags.length > 0) {
    if (matchMode === "any") {
      AND.push({ OR: selectedFlags.map((k) => ({ [k]: true })) });
    } else {
      for (const k of selectedFlags) AND.push({ [k]: true });
    }
  }

  const where = AND.length ? { AND } : undefined;

  // orderBy
  let orderBy = [{ nombre: "asc" }];
  switch (sortBy) {
    case "nombre_desc":
      orderBy = [{ nombre: "desc" }];
      break;
    case "ciudad_asc":
      orderBy = [{ ciudad: "asc" }, { localidad: "asc" }, { nombre: "asc" }];
      break;
    case "ciudad_desc":
      orderBy = [{ ciudad: "desc" }, { localidad: "desc" }, { nombre: "asc" }];
      break;
    case "nombre_asc":
    default:
      orderBy = [{ nombre: "asc" }];
  }

  // Consulta + total
  const [total, items] = await Promise.all([
    prisma.restaurante.count({ where }),
    prisma.restaurante.findMany({ where, orderBy, skip, take }),
  ]);

  return { items, total, page, pageSize };
};

/* -------------------- (legacy) obtener con filtros simples ------------- */
exports.obtenerTodos = async (query = {}) => {
  const {
    direccion,
    ciudad,
    provincia,
    localidad,
    zonaAmplia,
    parqueCercano,
    zonaInfantil,
    menuInfantil,
    tronaDisponible,
    cambiadorDisponible,
    sitioParaCarrito,
    terrazaSegura,
    ambienteFamiliar,
    sinPantallas,
    aptoVegetariano,
    aptoVegano,
    actividadesParaNinos,
    accesibleConCarrito,
    activo,
    verificado,
  } = query;

  const filtros = {};
  if (isFilled(direccion))
    filtros.direccion = { contains: toStr(direccion), mode: "insensitive" };
  if (isFilled(ciudad))
    filtros.ciudad = { contains: toStr(ciudad), mode: "insensitive" };
  if (isFilled(provincia))
    filtros.provincia = { contains: toStr(provincia), mode: "insensitive" };
  if (isFilled(localidad))
    filtros.localidad = { contains: toStr(localidad), mode: "insensitive" };

  // booleanos
  if (zonaAmplia != null) filtros.zonaAmplia = parseBool(zonaAmplia);
  if (parqueCercano != null) filtros.parqueCercano = parseBool(parqueCercano);
  if (zonaInfantil != null) filtros.zonaInfantil = parseBool(zonaInfantil);
  if (menuInfantil != null) filtros.menuInfantil = parseBool(menuInfantil);
  if (tronaDisponible != null)
    filtros.tronaDisponible = parseBool(tronaDisponible);
  if (cambiadorDisponible != null)
    filtros.cambiadorDisponible = parseBool(cambiadorDisponible);
  if (sitioParaCarrito != null)
    filtros.sitioParaCarrito = parseBool(sitioParaCarrito);
  if (terrazaSegura != null) filtros.terrazaSegura = parseBool(terrazaSegura);
  if (ambienteFamiliar != null)
    filtros.ambienteFamiliar = parseBool(ambienteFamiliar);
  if (sinPantallas != null) filtros.sinPantallas = parseBool(sinPantallas);
  if (aptoVegetariano != null)
    filtros.aptoVegetariano = parseBool(aptoVegetariano);
  if (aptoVegano != null) filtros.aptoVegano = parseBool(aptoVegano);
  if (actividadesParaNinos != null)
    filtros.actividadesParaNinos = parseBool(actividadesParaNinos);
  if (accesibleConCarrito != null)
    filtros.accesibleConCarrito = parseBool(accesibleConCarrito);
  if (activo != null) filtros.activo = parseBool(activo);
  if (verificado != null) filtros.verificado = parseBool(verificado);

  return prisma.restaurante.findMany({
    where: filtros,
    orderBy: { createdAt: "desc" },
  });
};

/* ---------------------------- utilidades CRUD --------------------------- */
exports.obtenerPorId = (id) =>
  prisma.restaurante.findUnique({ where: { id: Number(id) } });

exports.obtenerPorSlug = (slug) =>
  prisma.restaurante.findUnique({ where: { slug } });

exports.actualizar = (id, data) => {
  const actualizaSlug =
    data.nombre && typeof data.nombre === "string"
      ? slugify(data.nombre, { lower: true, strict: true })
      : undefined;

  return prisma.restaurante.update({
    where: { id: Number(id) },
    data: {
      ...data,
      slug: actualizaSlug || undefined,
      imagenes: Array.isArray(data.imagenes) ? data.imagenes : undefined,
    },
  });
};

exports.eliminar = (id) =>
  prisma.restaurante.delete({ where: { id: Number(id) } });
