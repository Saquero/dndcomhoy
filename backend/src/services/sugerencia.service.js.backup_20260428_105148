const { PrismaClient, EstadoSugerencia } = require("@prisma/client");
const prisma = new PrismaClient();
const slugify = require("slugify");

/** Crear */
exports.crearSugerencia = async (data) => {
  try {
    const slug = slugify(data.nombre, { lower: true, strict: true });
    return await prisma.sugerencia.create({
      data: {
        nombre: data.nombre,
        slug, // ahora existe en el modelo
        direccion: data.direccion,
        descripcion: data.descripcion,
        localidad: data.localidad,
        ciudad: data.ciudad,
        provincia: data.provincia,
        nombreContacto: data.nombreContacto,
        emailContacto: data.emailContacto || null,
        comentarios: data.comentarios || null,

        zonaAmplia: !!data.zonaAmplia,
        parqueCercano: !!data.parqueCercano,
        zonaInfantil: !!data.zonaInfantil,
        tronaDisponible: !!data.tronaDisponible,
        cambiadorDisponible: !!data.cambiadorDisponible,
        sitioParaCarrito: !!data.sitioParaCarrito,
        terrazaSegura: !!data.terrazaSegura,
        actividadesParaNinos: !!data.actividadesParaNinos,
        menuInfantil: !!data.menuInfantil,
        aptoVegetariano: !!data.aptoVegetariano,
        aptoVegano: !!data.aptoVegano,
        sinPantallas: !!data.sinPantallas,
        ambienteFamiliar: !!data.ambienteFamiliar,
        accesibleConCarrito: !!data.accesibleConCarrito,

        codigoPostal: data.codigoPostal || null,
        pais: data.pais || null,

        latitud: data.latitud ?? null,
        longitud: data.longitud ?? null,

        // estado por defecto: PENDIENTE (definido en Prisma)
      },
    });
  } catch (error) {
    throw new Error("Error creando sugerencia: " + error.message);
  }
};

/** Listado paginado + filtros + búsqueda */
exports.obtenerTodos = async ({
  page = 1,
  pageSize = 20,
  estado,
  search,
} = {}) => {
  try {
    const where = {};
    if (estado) {
      // admitimos 'pendiente'/'PENDIENTE'/'Pendiente'
      const normalized = String(estado).toUpperCase();
      if (
        ["PENDIENTE", "APROBADA", "RECHAZADA", "DUPLICADA"].includes(normalized)
      ) {
        where.estado = EstadoSugerencia[normalized];
      }
    }
    if (search && search.trim()) {
      where.OR = [
        { nombre: { contains: search, mode: "insensitive" } },
        { direccion: { contains: search, mode: "insensitive" } },
        { ciudad: { contains: search, mode: "insensitive" } },
        { provincia: { contains: search, mode: "insensitive" } },
      ];
    }

    const [total, data] = await Promise.all([
      prisma.sugerencia.count({ where }),
      prisma.sugerencia.findMany({
        where,
        skip: (page - 1) * pageSize,
        take: pageSize,
        orderBy: { creadaEn: "desc" },
      }),
    ]);

    return {
      data,
      meta: {
        total,
        page,
        pageSize,
        pages: Math.max(1, Math.ceil(total / pageSize)),
      },
    };
  } catch (error) {
    throw new Error("Error obteniendo sugerencias: " + error.message);
  }
};

/** Legacy sin paginar (lo dejo por compat) */
exports.obtenerSugerencias = async () => {
  try {
    return await prisma.sugerencia.findMany({
      orderBy: { creadaEn: "desc" },
    });
  } catch (error) {
    throw new Error("Error obteniendo sugerencias: " + error.message);
  }
};

/** Por ID */
exports.obtenerPorId = async (id) => {
  try {
    return await prisma.sugerencia.findUnique({
      where: { id: Number(id) },
    });
  } catch (error) {
    throw new Error("Error obteniendo sugerencia por ID: " + error.message);
  }
};

/** Update completo (PUT) */
exports.actualizarSugerencia = async (id, data) => {
  try {
    const actualizaSlug =
      data.nombre && typeof data.nombre === "string"
        ? slugify(data.nombre, { lower: true, strict: true })
        : undefined;

    return await prisma.sugerencia.update({
      where: { id: Number(id) },
      data: {
        ...data,
        slug: actualizaSlug || undefined,
      },
    });
  } catch (error) {
    throw new Error("Error actualizando sugerencia: " + error.message);
  }
};

/** PATCH solo estado (acepta minúsculas y mayúsculas) */
exports.actualizarEstado = async (id, estado) => {
  try {
    const normalized = String(estado).toUpperCase();
    if (
      !["PENDIENTE", "APROBADA", "RECHAZADA", "DUPLICADA"].includes(normalized)
    ) {
      return null;
    }
    const sug = await prisma.sugerencia.update({
      where: { id: Number(id) },
      data: { estado: EstadoSugerencia[normalized] },
    });
    return sug;
  } catch {
    return null;
  }
};

/** Eliminar */
exports.eliminar = async (id) => {
  try {
    return await prisma.sugerencia.delete({
      where: { id: Number(id) },
    });
  } catch (error) {
    throw new Error("Error eliminando sugerencia: " + error.message);
  }
};
